# JWT Configuration
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=your-strong-random-secret-here-change-in-production

# Database
MONGODB_URI=mongodb://localhost:27017/e-lawyer
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/e-lawyer?retryWrites=true&w=majority

# Server Configuration
NODE_ENV=development
PORT=5100

# CORS
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5180,https://localhost:5180

# AI Services
# For Gemini AI integration
GEMINI_API_KEY=your-gemini-api-key

# Frontend URLs
FRONTEND_BASE_URL=http://localhost:5180
APP_ORIGIN=http://localhost:5180

# Optional: Disable background jobs for testing
# DISABLE_JOBS=1

# Optional: Force test mode
# NODE_ENV=test
